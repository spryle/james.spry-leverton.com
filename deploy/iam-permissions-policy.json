{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "S3SyncToSiteBucket",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket",
                "s3:GetBucketLocation"
            ],
            "Resource": "arn:aws:s3:::james.spry-leverton.com"
        },
        {
            "Sid": "S3ObjectWriteOnSiteBucket",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject"
            ],
            "Resource": "arn:aws:s3:::james.spry-leverton.com/*"
        },
        {
            "Sid": "CloudFrontInvalidate",
            "Effect": "Allow",
            "Action": "cloudfront:CreateInvalidation",
            "Resource": "*"
        }
    ]
}
